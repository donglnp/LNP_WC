# --- World Cup API ---
# football-data.org is CORS-restricted, so the browser can't call it directly.
# In DEV: set VITE_FD_TOKEN. Vite proxies /api/fd/* → football-data.org and
#          injects the X-Auth-Token header server-side (see vite.config.js).
# In PROD: set VITE_FD_PROXY to the URL of your own serverless proxy
#          (e.g. https://your-app.com/api/fd) that does the same header inject.
# If neither is set, the app falls back to TheSportsDB (no key), then to mock.
VITE_FD_TOKEN=
VITE_FD_PROXY=

# --- Supabase (optional, for shared voting) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
