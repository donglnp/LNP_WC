# =====================================================================
# Two naming conventions — read this once and the rest will make sense:
#
#   VITE_*    → INLINED into the JS bundle at build time. Visible to
#               anyone who opens DevTools. Use ONLY for values that
#               are safe to be public (URLs, publishable keys).
#
#   (no prefix) → Server-side only. Read by vite.config.js (dev) or
#               the Vercel function in api/fd/ (prod). NEVER reaches
#               the browser. Use for tokens & secrets.
#
# The exact same variable names work in BOTH .env (local) and on
# Vercel (Project Settings → Environment Variables).
# =====================================================================

# ---- HUB Supabase (auth + user profile + game catalog) ----
# Schema lives in supabase/hub-schema.sql
VITE_SUPABASE_URL=https://<hub-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt

# ---- WC Supabase (predictions + match results) ----
# Schema lives in supabase/wc-schema.sql
# OPTIONAL: leave blank to fall back to VITE_SUPABASE_URL/ANON_KEY (single Supabase setup).
VITE_WC_SUPABASE_URL=
VITE_WC_SUPABASE_ANON_KEY=

# ---- football-data.org token (SECRET — never in the bundle) ----
# Get one free at https://www.football-data.org/client/register
# In dev: Vite's proxy in vite.config.js reads this and injects the
#         X-Auth-Token header server-side.
# In prod: the Vercel function api/fd/[...path].js reads this and does
#         the same injection. The browser only ever calls /api/fd/*.
FD_TOKEN=

# ---- Optional: override the proxy URL ----
# Leave blank to use the bundled /api/fd proxy (Vite dev or Vercel function).
# Set to https://your-other-host.com/api/fd if hosting elsewhere.
VITE_FD_PROXY=
